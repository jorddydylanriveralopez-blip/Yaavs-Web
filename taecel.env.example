# TAECEL — recargas de tiempo aire (solo servidor / Vercel)
# 1. Crea cuenta en https://taecel.com/
# 2. Envía el levantamiento: https://taecel.com/portal/integracion-web-services
# 3. Pegá las claves en Vercel → Project → Settings → Environment Variables
# 4. Pon TAECEL_DEMO=0 cuando las pruebas estén verificadas

TAECEL_DEMO=1
TAECEL_KEY=
TAECEL_NIP=
# URL base del API que te entregue TAECEL (ej. https://taecel.com/app/api/)
TAECEL_API_BASE=
